{
  "name": "css-modules-lint",
  "version": "1.0.2",
  "type": "module",
  "description": "Lint, autocomplete, and generate types for CSS Modules. Includes a TypeScript language service plugin, CLI, Vite plugin, and ESLint plugin.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "default": "./dist/vite-plugin.js"
    },
    "./eslint": {
      "types": "./dist/eslint-plugin.d.ts",
      "default": "./dist/eslint-plugin.js"
    }
  },
  "bin": {
    "css-modules-lint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "typescript",
    "plugin",
    "css-modules",
    "scss",
    "lint"
  ],
  "author": {
    "name": "Brendan Kemp",
    "email": "brendan.kemp@gmail.com"
  },
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "eslint": {
      "optional": true
    }
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "postcss": "^8.5.8",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "postcss-selector-parser": "^7.1.1"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}
