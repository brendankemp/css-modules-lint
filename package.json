{
  "name": "ts-css-modules-lint",
  "version": "1.0.0",
  "description": "TypeScript-enabled checking of CSS Modules: cross-file unused class detection, autocomplete, and go-to-definition",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./vite": {
      "types": "./build/vite-plugin.d.ts",
      "default": "./build/vite-plugin.js"
    },
    "./eslint": {
      "types": "./build/eslint-plugin.d.ts",
      "default": "./build/eslint-plugin.js"
    }
  },
  "bin": {
    "css-modules-lint": "./build/cli.js"
  },
  "files": [
    "build",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf build && tsc && chmod +x build/cli.js",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "typescript",
    "plugin",
    "css-modules",
    "scss",
    "lint"
  ],
  "author": {
    "name": "Brendan Kemp",
    "email": "brendan.kemp@gmail.com"
  },
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "eslint": {
      "optional": true
    }
  },
  "dependencies": {
    "magicast": "^0.5.2",
    "postcss": "^8.5.8",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "postcss-selector-parser": "^7.1.1"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}
